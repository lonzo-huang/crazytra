# Shared Dockerfile for strategy-layer and llm-layer
FROM python:3.12-slim-bookworm

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1

WORKDIR /app

# Install system deps
RUN apt-get update && apt-get install -y gcc && rm -rf /var/lib/apt/lists/*

# Install Python deps first (cache layer)
COPY pyproject.toml ./
RUN pip install --upgrade pip && pip install -e ".[all]" 2>/dev/null || pip install -e . || true

# Copy source
COPY . .
RUN pip install -e .

# Run the appropriate module (set via CMD in docker-compose or k8s)
CMD ["python", "-m", "strategy_layer.main"]
