# Nautilus Trader 环境配置模板
# 复制此文件为 .env 并填写实际值

# ===== Redis 配置 =====
REDIS_URL=redis://localhost:6379
REDIS_DB=0

# ===== 交易模式 =====
# 可选值: paper (纸面交易) | live (实盘交易)
TRADING_MODE=paper

# ===== Binance 配置 =====
BINANCE_API_KEY=
BINANCE_SECRET=
BINANCE_TESTNET=false

# ===== Polymarket 配置 =====
POLYMARKET_API_KEY=
POLYMARKET_WALLET_ADDRESS=

# ===== 风控参数 =====
MAX_POSITION_SIZE=0.20
MAX_DAILY_LOSS=0.05
MAX_DRAWDOWN=0.15
PAPER_INITIAL_CASH=100000

# ===== LLM 配置 =====
# LLM 层独立运行，这里只配置权重衰减参数
LLM_HALF_LIFE_S=1800  # 30分钟

# ===== 回测配置 =====
BACKTEST_DATA_PATH=./data
BACKTEST_START=2024-01-01
BACKTEST_END=2024-12-31

# ===== 日志配置 =====
LOG_LEVEL=INFO
LOG_DIRECTORY=./logs
