# LLM 层环境变量配置示例
# 复制此文件为 .env 并填写实际值

# ============================================
# 必需配置
# ============================================

# Redis 连接 URL
REDIS_URL=redis://localhost:6379

# ============================================
# Ollama 配置 (本地 LLM，推荐)
# ============================================

# Ollama 服务地址
OLLAMA_BASE_URL=http://localhost:11434

# Ollama 模型名称
# 推荐模型：
# - mistral:7b-instruct-q4_K_M (快速，7GB)
# - llama3:8b-instruct-q4_K_M (准确，8GB)
# - qwen2.5:7b-instruct-q4_K_M (中文友好，7GB)
OLLAMA_MODEL=mistral:7b-instruct-q4_K_M

# ============================================
# 云端 LLM 配置 (可选，用于重大新闻)
# ============================================

# Anthropic Claude API Key
# 获取：https://console.anthropic.com/
# 成本：~$0.003/1k tokens (输入) + $0.015/1k tokens (输出)
ANTHROPIC_API_KEY=

# OpenAI API Key
# 获取：https://platform.openai.com/api-keys
# 成本：~$0.005/1k tokens (输入) + $0.015/1k tokens (输出)
OPENAI_API_KEY=

# ============================================
# NewsAPI 配置 (可选，提高新闻质量)
# ============================================

# NewsAPI Key
# 获取：https://newsapi.org/register
# 免费版：100 请求/天
NEWSAPI_KEY=

# ============================================
# 运行参数
# ============================================

# 常规分析间隔（秒）
# 默认：300 (5 分钟)
# 建议：180-600
LLM_INTERVAL_S=300

# 重大新闻重要性阈值
# 默认：0.85
# 范围：0.0-1.0
# 说明：超过此阈值的新闻会触发云端 LLM 分析
BREAKING_THRESHOLD=0.85

# ============================================
# 高级配置 (通常不需要修改)
# ============================================

# 日志级别
# 选项：DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# 缓存 TTL（秒）
# 默认：180 (3 分钟)
CACHE_TTL_S=180

# 时间衰减半衰期（分钟）
# 默认：30
HALF_LIFE_MIN=30

# 新闻最大年龄（小时）
# 默认：4
MAX_NEWS_AGE_H=4

# 最大新闻数量
# 默认：15
MAX_NEWS_ITEMS=15
