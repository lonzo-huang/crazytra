# ── 消息总线 ──────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
KAFKA_BROKERS=localhost:9092

# ── 数据库 ────────────────────────────────────────────────
DATABASE_URL=postgresql://trader:trader@localhost:5432/trading
TIMESCALE_URL=postgresql://trader:trader@localhost:5432/market_data

# ── 交易所 API ────────────────────────────────────────────
BINANCE_API_KEY=your_binance_api_key
BINANCE_SECRET=your_binance_secret
TIGER_ACCESS_TOKEN=your_tiger_token
TRADING212_API_KEY=your_trading212_key

# ── LLM Providers ─────────────────────────────────────────
OPENAI_API_KEY=your_openai_key
ANTHROPIC_API_KEY=your_anthropic_key
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral:7b-instruct-q4_K_M

# ── 新闻 API ──────────────────────────────────────────────
NEWSAPI_KEY=your_newsapi_key

# ── 交易模式 ──────────────────────────────────────────────
TRADING_MODE=paper            # paper | live
PAPER_INITIAL_CASH=100000

# ── 风控参数 ──────────────────────────────────────────────
MAX_POSITION_SIZE=0.2         # 单仓最大 20%
MAX_DAILY_LOSS=0.05           # 日亏损上限 5%
MAX_DRAWDOWN=0.15             # 最大回撤 15%

# ── API 网关 ──────────────────────────────────────────────
API_PORT=8080
JWT_SECRET=change_me_in_production

# ── 前端 ──────────────────────────────────────────────────
VITE_API_URL=http://localhost:8080
VITE_WS_URL=ws://localhost:8080

# ── Telegram Bot ──────────────────────────────────────────
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
TELEGRAM_CHAT_ID=123456789
TELEGRAM_ENABLE=true
